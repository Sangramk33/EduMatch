<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Feedback | Admin</title>

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        *{
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: linear-gradient(135deg,#f1f5ff,#f8fafc);
        }

        /* Sidebar */
        .sidebar {
            height: 100vh;
            width: 240px;
            position: fixed;
            background: linear-gradient(180deg,#4f46e5,#6366f1);
            color: white;
            padding-top: 20px;
            box-shadow: 4px 0 20px rgba(236, 233, 233, 0.1);
        }

        .sidebar a {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: #e0e7ff;
            text-decoration: none;
            border-radius: 10px;
            margin: 5px 10px;
            transition: 0.3s;
        }

        .sidebar a:hover {
            background: rgba(255,255,255,0.2);
            transform: translateX(5px);
        }

        /* Content */
        .content {
            margin-left: 240px;
            padding: 30px;
        }

        h4 {
            color: #1e293b;
        }

        /* Card */
        .feedback-card {
            border-radius: 16px;
            border: none;
            background: white;
            box-shadow: 0 8px 20px rgba(255, 255, 255, 0.06);
            transition: 0.3s;
        }

        .feedback-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px rgba(248, 245, 245, 0.1);
        }

        /* Reply Box */
        .admin-reply {
            background: linear-gradient(135deg,#e0f2fe,#bae6fd);
            border-left: 4px solid #2563eb;
            padding: 12px 15px;
            border-radius: 0 10px 10px 0;
        }

        /* Input */
        .form-control {
            border-radius: 10px;
            padding: 10px;
            border: 1px solid #e2e8f0;
        }

        .form-control:focus {
            box-shadow: 0 0 0 2px rgba(37,99,235,0.2);
            border-color: #2563eb;
        }

        /* Button */
        .btn-custom {
            border-radius: 10px;
            background: linear-gradient(135deg,#2563eb,#3b82f6);
            color: white;
            border: none;
            transition: 0.3s;
        }

        .btn-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(37,99,235,0.3);
        }

        /* Empty alert */
        .alert {
            border-radius: 12px;
        }

    </style>
</head>
<body>

<!-- Sidebar -->
<div class="sidebar">
    <h4 class="text-center mb-4">EduMatch Admin</h4>

    <a href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/admin/students"><i class="bi bi-people me-2"></i> Students</a>
    <a href="/admin/colleges"><i class="bi bi-building me-2"></i> Colleges</a>
    <a href="/admin/feedback"><i class="bi bi-chat-dots me-2"></i> Feedback</a>
    <a href="#" onclick="document.getElementById('logoutModal').style.display='flex'">
        <i class="bi bi-box-arrow-right me-2"></i> Logout
    </a>
</div>

<!-- Content -->
<div class="content">

    <h4 class="mb-4 fw-semibold">
        <i class="bi bi-chat-dots me-2"></i> Student Feedback
    </h4>

    <% if (feedbacks && feedbacks.length > 0) { %>
        <% feedbacks.forEach(function(fb) { %>

            <div class="card feedback-card mb-3">
                <div class="card-body">

                    <div class="d-flex justify-content-between mb-2">
                        <strong>
                            <i class="bi bi-person me-1"></i>
                            <%= fb.student_name %>
                        </strong>

                        <small class="text-muted">
                            <%= new Date(fb.created_at).toLocaleDateString('en-IN') %>
                        </small>
                    </div>

                    <p class="mb-3"><%= fb.message %></p>

                    <% if (fb.admin_reply) { %>

                        <div class="admin-reply">
                            <small class="fw-bold text-primary">
                                <i class="bi bi-person-badge me-1"></i> Your Reply:
                            </small>
                            <p class="mb-0 mt-1"><%= fb.admin_reply %></p>
                        </div>

                    <% } else { %>

                        <form action="/admin/reply-feedback/<%= fb.id %>" method="POST" class="mt-2">
                            <div class="d-flex gap-2">
                                <input type="text" name="reply" class="form-control"
                                       placeholder="Write your reply..." required>

                                <button type="submit" class="btn-custom px-3">
                                    <i class="bi bi-send"></i>
                                </button>
                            </div>
                        </form>

                    <% } %>

                </div>
            </div>

        <% }); %>

    <% } else { %>

        <div class="alert alert-info shadow-sm">
            <i class="bi bi-info-circle me-2"></i>
            No feedback received yet.
        </div>

    <% } %>

</div>

<!-- Logout Modal SAME -->
<div id="logoutModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.4); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:20px; padding:30px; width:350px; text-align:center;">
        <div style="font-size:35px;">🚪</div>
        <h5 class="mt-3 fw-bold">Logout?</h5>
        <p class="text-muted">Do you really want to logout?</p>

        <div class="d-flex gap-2 mt-3">
            <button onclick="document.getElementById('logoutModal').style.display='none'"
                class="btn btn-outline-secondary w-100">
                Stay
            </button>

            <button onclick="window.location.href='/admin/logout'"
                class="btn btn-danger w-100">
                Logout
            </button>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    sessionStorage.setItem('onAdminDashboard', 'true');
    history.pushState(null, null, location.href);

    window.addEventListener('pageshow', function() {
        history.pushState(null, null, location.href);
    });

    window.onpopstate = function () {
        history.pushState(null, null, location.href);
        document.getElementById('logoutModal').style.display = 'flex';
    };
</script>

</body>
</html>