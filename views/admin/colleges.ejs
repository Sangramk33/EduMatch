<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Colleges | Admin</title>

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        *{ font-family: 'Poppins', sans-serif; }
        body { background: linear-gradient(135deg,#eef2ff,#f8fafc); }

        .sidebar {
            height: 100vh; width: 240px; position: fixed;
            background: linear-gradient(180deg,#4f46e5,#6366f1);
            color: white; padding-top: 20px;
            box-shadow: 4px 0 20px rgba(0,0,0,0.1);
        }
        .sidebar a {
            display: flex; align-items: center;
            padding: 12px 20px; color: #e0e7ff;
            text-decoration: none; border-radius: 10px;
            margin: 5px 10px; transition: 0.3s;
        }
        .sidebar a:hover { background: rgba(255,255,255,0.2); transform: translateX(5px); }

        .content { margin-left: 240px; padding: 30px; }

        .custom-card { border-radius: 16px; border: none; box-shadow: 0 10px 25px rgba(0,0,0,0.08); }

        .form-control, .form-select { border-radius: 10px; padding: 10px; }

        .btn-custom {
            border-radius: 12px; padding: 10px 20px;
            background: linear-gradient(135deg,#6366f1,#4f46e5);
            color: white; border: none; transition: 0.3s;
        }
        .btn-custom:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(79,70,229,0.3); }

        .table thead { background: linear-gradient(135deg,#6366f1,#4f46e5); color: white; }
        .table { border-radius: 12px; overflow: hidden; }
        .table-hover tbody tr:hover { background: #eef2ff; }
    </style>
</head>
<body>

<!-- Sidebar -->
<div class="sidebar">
    <h4 class="text-center mb-4">EduMatch Colleges</h4>
    <a href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/admin/students"><i class="bi bi-people me-2"></i> Students</a>
    <a href="/admin/colleges"><i class="bi bi-building me-2"></i> Colleges</a>
    <a href="/admin/feedback"><i class="bi bi-chat-dots me-2"></i> Feedback</a>
    <a href="#" onclick="document.getElementById('logoutModal').style.display='flex'">
        <i class="bi bi-box-arrow-right me-2"></i> Logout
    </a>
</div>

<!-- Content -->
<div class="content">

    <h4 class="mb-4 fw-semibold">
        <i class="bi bi-building me-2"></i> Manage Colleges
    </h4>

    <!-- Add College -->
    <div class="card custom-card mb-4">
        <div class="card-body">
            <h6 class="mb-3 fw-semibold">Add New College</h6>

            <form action="/admin/add-college" method="POST">
                <div class="row g-3">
                    <div class="col-md-3">
                        <input type="text" name="name" class="form-control" placeholder="College Name" required>
                    </div>
                    <div class="col-md-2">
                        <input type="text" name="city" class="form-control" value="Pune" required>
                    </div>
                    <div class="col-md-2">
                        <select name="course" class="form-select" required>
                            <option value="MCA">MCA</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="number" name="cutoff_percentage" class="form-control"
                               placeholder="Cutoff %" min="0" max="100" required>
                    </div>
                    <!-- ✅ NEW: Website URL -->
                    <div class="col-md-3">
                        <input type="url" name="website" class="form-control" placeholder="Website URL (https://...)">
                    </div>
                </div>

                <!-- Amenities -->
                <div class="mt-3">
                    <label class="fw-semibold mb-2">Amenities:</label>
                    <div class="d-flex gap-3 flex-wrap">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="hostel" value="1">
                            <label class="form-check-label">🏠 Hostel</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="labs" value="1" checked>
                            <label class="form-check-label">💻 Labs</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="library" value="1" checked>
                            <label class="form-check-label">📚 Library</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="sports" value="1">
                            <label class="form-check-label">🏆 Sports</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="canteen" value="1" checked>
                            <label class="form-check-label">☕ Canteen</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="wifi" value="1" checked>
                            <label class="form-check-label">📶 WiFi</label>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn-custom">
                        <i class="bi bi-plus-circle me-1"></i> Add College
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card custom-card">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>City</th>
                        <th>Course</th>
                        <th>Cutoff %</th>
                        <th>Website</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (colleges && colleges.length > 0) { %>
                        <% colleges.forEach(function(c, i) { %>
                            <tr>
                                <td><%= i + 1 %></td>
                                <td><%= c.name %></td>
                                <td><%= c.city %></td>
                                <td><%= c.course %></td>
                                <td><%= c.cutoff_percentage || 'N/A' %>%</td>
                                <!-- ✅ NEW: Website link -->
                                <td>
                                    <% if (c.website) { %>
                                        <a href="<%= c.website %>" target="_blank" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-globe"></i> Visit
                                        </a>
                                    <% } else { %>
                                        <span class="text-muted" style="font-size:13px">—</span>
                                    <% } %>
                                </td>
                                <td>
                                    <a href="/admin/delete-college/<%= c.id %>"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Delete this college?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center text-muted">No colleges found</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- Logout Modal -->
<div id="logoutModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.4); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:20px; padding:30px; width:350px; text-align:center;">
        <div style="font-size:35px;">🚪</div>
        <h5 class="mt-3 fw-bold">Logout?</h5>
        <p class="text-muted">Do you really want to logout?</p>
        <div class="d-flex gap-2 mt-3">
            <button onclick="document.getElementById('logoutModal').style.display='none'" class="btn btn-outline-secondary w-100">Stay</button>
            <button onclick="window.location.href='/admin/logout'" class="btn btn-danger w-100">Logout</button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    sessionStorage.setItem('onAdminDashboard', 'true');
    history.pushState(null, null, location.href);
    window.addEventListener('pageshow', function() { history.pushState(null, null, location.href); });
    window.onpopstate = function () {
        history.pushState(null, null, location.href);
        document.getElementById('logoutModal').style.display = 'flex';
    };
</script>
</body>
</html>
