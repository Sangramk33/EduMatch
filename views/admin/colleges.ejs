<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Colleges | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background: #f4f6f9; }
        .sidebar { height: 100vh; background: #1e293b; color: white; position: fixed; width: 220px; padding-top: 20px; }
        .sidebar a { color: #cbd5e1; display: block; padding: 12px 20px; text-decoration: none; }
        .sidebar a:hover { background: #334155; color: white; }
        .content { margin-left: 220px; padding: 30px; }
    </style>
</head>
<body>
<div class="sidebar">
    <h4 class="text-center mb-4">EduMatch Admin</h4>
    <a href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/admin/students"><i class="bi bi-people me-2"></i> Students</a>
    <a href="/admin/colleges"><i class="bi bi-building me-2"></i> Colleges</a>
    <a href="/admin/feedback"><i class="bi bi-chat-dots me-2"></i> Feedback</a>
    <a href="/admin/logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a>
</div>
<div class="content">
    <h4 class="mb-4"><i class="bi bi-building me-2"></i>Manage Colleges</h4>

    <!-- Add College Form -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h6 class="mb-3">Add New College</h6>
            <form action="/admin/add-college" method="POST">
                <div class="row g-2">
                    <div class="col-md-3">
                        <input type="text" name="name" class="form-control" placeholder="College Name" required>
                    </div>
                    <div class="col-md-2">
                        <input type="text" name="city" class="form-control" placeholder="City" value="Pune" required>
                    </div>
                    <div class="col-md-2">
                        <select name="course" class="form-control" required>
                            <option value="MCA">MCA</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="number" name="cutoff_percentage" class="form-control"
                               placeholder="Cutoff %" min="0" max="100" required>
                    </div>
                </div>

                <div class="mt-3">
                    <label class="fw-bold mb-2">Amenities:</label>
                    <div class="d-flex gap-3 flex-wrap">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="hostel" value="1">
                            <label class="form-check-label">🏠 Hostel</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="labs" value="1" checked>
                            <label class="form-check-label">💻 Labs</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="library" value="1" checked>
                            <label class="form-check-label">📚 Library</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="sports" value="1">
                            <label class="form-check-label">🏆 Sports</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="canteen" value="1" checked>
                            <label class="form-check-label">☕ Canteen</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="wifi" value="1" checked>
                            <label class="form-check-label">📶 WiFi</label>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-plus-circle me-1"></i>Add College
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Colleges Table -->
    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>City</th>
                        <th>Course</th>
                        <th>Cutoff %</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (colleges && colleges.length > 0) { %>
                        <% colleges.forEach(function(c, i) { %>
                            <tr>
                                <td><%= i + 1 %></td>
                                <td><%= c.name %></td>
                                <td><%= c.city %></td>
                                <td><%= c.course %></td>
                                <td><%= c.cutoff_percentage || 'N/A' %>%</td>
                                <td>
                                    <a href="/admin/delete-college/<%= c.id %>"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Delete this college?')">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="6" class="text-center text-muted">No colleges found.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Custom Logout Modal -->
<div id="logoutModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:20px; padding:36px; width:380px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
        <div style="width:60px; height:60px; background:#fef2f2; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:28px;">🚪</div>
        <h5 style="font-size:18px; font-weight:700; color:#1e1b4b; margin-bottom:8px;">Leaving so soon?</h5>
        <p style="font-size:13px; color:#6b7280; margin-bottom:24px;">Do you want to logout and go back?</p>
        <div style="display:flex; gap:12px;">
            <button onclick="document.getElementById('logoutModal').style.display='none'"
                style="flex:1; padding:11px; border:1.5px solid #e5e7eb; border-radius:12px; background:white; color:#374151; font-size:14px; font-weight:600; cursor:pointer;">
                Stay
            </button>
            <button onclick="window.location.href='/admin/logout'"
                style="flex:1; padding:11px; border:none; border-radius:12px; background:linear-gradient(135deg,#ef4444,#dc2626); color:white; font-size:14px; font-weight:600; cursor:pointer;">
                Logout
            </button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    sessionStorage.setItem('onAdminDashboard', 'true');
    history.pushState(null, null, location.href);

    window.addEventListener('pageshow', function() {
        history.pushState(null, null, location.href);
    });

    window.onpopstate = function () {
        history.pushState(null, null, location.href);
        document.getElementById('logoutModal').style.display = 'flex';
    };
</script>
</body>
</html>
