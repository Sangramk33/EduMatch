<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Students | Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body { background: #f4f6f9; }

        /* Sidebar */
        .sidebar {
            height: 100vh;
            width: 240px;
            position: fixed;
            background: linear-gradient(180deg,#4f46e5,#6366f1);
            color: white;
            padding-top: 20px;
            box-shadow: 4px 0 20px rgba(0,0,0,0.1);
        }

        .sidebar a {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: #e0e7ff;
            text-decoration: none;
            border-radius: 10px;
            margin: 5px 10px;
            transition: 0.3s;
        }

        .sidebar a:hover {
            background: rgba(255,255,255,0.2);
            transform: translateX(5px);
        }

        .content {
            margin-left: 220px;
            padding: 30px;
        }

        .card {
            border-radius: 12px;
            border: none;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .table thead {
            background: #2563eb;
            color: white;
        }

        .table tbody tr:hover {
            background: #f1f5ff;
        }

        .btn-danger {
            background: #ef4444;
            border: none;
            border-radius: 6px;
        }

        .btn-danger:hover {
            background: #dc2626;
        }
    </style>
</head>

<body>

<!-- Sidebar -->
<div class="sidebar">
    <h4 class="text-center mb-4">EduMatch Student</h4>
    <a href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/admin/students"><i class="bi bi-people me-2"></i> Students</a>
    <a href="/admin/colleges"><i class="bi bi-building me-2"></i> Colleges</a>
    <a href="/admin/feedback"><i class="bi bi-chat-dots me-2"></i> Feedback</a>
    <a href="/admin/logout" id="logoutBtn"><i class="bi bi-box-arrow-right me-2"></i> Logout</a>
</div>

<!-- Content -->
<div class="content">
    <h4 class="mb-4">
        <i class="bi bi-people me-2"></i>All Students
    </h4>

    <div class="card">
        <div class="card-body">

            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Mobile</th>
                        <th>CET %</th>
                        <th>City</th>
                        <th>Graduation</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    <% if (students && students.length > 0) { %>
                        <% students.forEach(function(s, i) { %>
                            <tr>
                                <td><%= i + 1 %></td>
                                <td><%= s.name %></td>
                                <td><%= s.email %></td>
                                <td><%= s.mobile || 'N/A' %></td>
                                <td><%= s.cet_percentage %>%</td>
                                <td><%= s.city %></td>
                                <td><%= s.graduation %></td>
                                <td>
                                    <a href="/admin/delete-student/<%= s.id %>"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Delete this student?')">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="8" class="text-center text-muted">
                                No students found.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>

        </div>
    </div>
</div>

<!-- Logout Modal (SAME AS COLLEGE PAGE) -->
<div id="logoutModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:20px; padding:36px; width:380px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
        <div style="width:60px; height:60px; background:#fef2f2; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:28px;">🚪</div>
        <h5 style="font-size:18px; font-weight:700; color:#1e1b4b; margin-bottom:8px;">Leaving so soon?</h5>
        <p style="font-size:13px; color:#6b7280; margin-bottom:24px;">Do you want to logout and go back?</p>
        <div style="display:flex; gap:12px;">
            <button onclick="document.getElementById('logoutModal').style.display='none'"
                style="flex:1; padding:11px; border:1.5px solid #e5e7eb; border-radius:12px; background:white; color:#374151; font-size:14px; font-weight:600; cursor:pointer;">
                Stay
            </button>
            <button onclick="window.location.href='/admin/logout'"
                style="flex:1; padding:11px; border:none; border-radius:12px; background:linear-gradient(135deg,#ef4444,#dc2626); color:white; font-size:14px; font-weight:600; cursor:pointer;">
                Logout
            </button>
        </div>
    </div>
</div>

<!-- Scripts SAME -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    sessionStorage.setItem('onAdminDashboard', 'true');

    history.pushState(null, null, location.href);

    window.addEventListener('pageshow', function() {
        history.pushState(null, null, location.href);
    });

    window.onpopstate = function () {
        history.pushState(null, null, location.href);
        document.getElementById('logoutModal').style.display = 'flex';
    };

    // Logout button click modal
    document.getElementById("logoutBtn").addEventListener("click", function(e){
        e.preventDefault();
        document.getElementById("logoutModal").style.display = "flex";
    });
</script>

</body>
</html>