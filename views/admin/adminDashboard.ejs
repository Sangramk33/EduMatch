<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard | EduMatch</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background: #f4f6f9; }
        .sidebar { height: 100vh; background: #1e293b; color: white; position: fixed; width: 220px; padding-top: 20px; }
        .sidebar a { color: #cbd5e1; display: block; padding: 12px 20px; text-decoration: none; }
        .sidebar a:hover { background: #334155; color: white; }
        .content { margin-left: 220px; padding: 30px; }
        .stat-card { border-radius: 12px; padding: 20px; color: white; }
    </style>
</head>
<body>

<div class="sidebar">
    <h4 class="text-center mb-4">EduMatch Admin</h4>
    <a href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/admin/students"><i class="bi bi-people me-2"></i> Students</a>
    <a href="/admin/colleges"><i class="bi bi-building me-2"></i> Colleges</a>
    <a href="/admin/feedback"><i class="bi bi-chat-dots me-2"></i> Feedback</a>
    <a href="/admin/logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a>
</div>

<div class="content">
    <h4 class="mb-4">Welcome, <%= admin.name %> 👋</h4>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card" style="background:#0d6efd">
                <h2><%= totalStudents %></h2>
                <p class="mb-0"><i class="bi bi-people me-2"></i>Total Students</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card" style="background:#198754">
                <h2><%= totalColleges %></h2>
                <p class="mb-0"><i class="bi bi-building me-2"></i>Total Colleges</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card" style="background:#ffc107">
                <h2><%= pendingFeedbacks %></h2>
                <p class="mb-0"><i class="bi bi-chat-dots me-2"></i>Pending Feedbacks</p>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <a href="/admin/students" class="btn btn-outline-primary w-100 py-3">
                <i class="bi bi-people fs-4 d-block mb-2"></i>Manage Students
            </a>
        </div>
        <div class="col-md-4">
            <a href="/admin/colleges" class="btn btn-outline-success w-100 py-3">
                <i class="bi bi-building fs-4 d-block mb-2"></i>Manage Colleges
            </a>
        </div>
        <div class="col-md-4">
            <a href="/admin/feedback" class="btn btn-outline-warning w-100 py-3">
                <i class="bi bi-chat-dots fs-4 d-block mb-2"></i>View Feedback
            </a>
        </div>
    </div>
</div>

<!-- Custom Logout Modal -->
<div id="logoutModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:20px; padding:36px; width:380px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
        <div style="width:60px; height:60px; background:#fef2f2; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:28px;">🚪</div>
        <h5 style="font-size:18px; font-weight:700; color:#1e1b4b; margin-bottom:8px;">Leaving so soon?</h5>
        <p style="font-size:13px; color:#6b7280; margin-bottom:24px;">Do you want to logout and go back?</p>
        <div style="display:flex; gap:12px;">
            <button onclick="document.getElementById('logoutModal').style.display='none'"
                style="flex:1; padding:11px; border:1.5px solid #e5e7eb; border-radius:12px; background:white; color:#374151; font-size:14px; font-weight:600; cursor:pointer;">
                Stay
            </button>
            <button onclick="window.location.href='/admin/logout'"
                style="flex:1; padding:11px; border:none; border-radius:12px; background:linear-gradient(135deg,#ef4444,#dc2626); color:white; font-size:14px; font-weight:600; cursor:pointer;">
                Logout
            </button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    sessionStorage.setItem('onAdminDashboard', 'true');
    history.pushState(null, null, location.href);

    window.addEventListener('pageshow', function() {
        history.pushState(null, null, location.href);
    });

    window.onpopstate = function () {
        history.pushState(null, null, location.href);
        document.getElementById('logoutModal').style.display = 'flex';
    };
</script>

</body>
</html>
