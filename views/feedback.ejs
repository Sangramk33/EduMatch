<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Feedback | EduMatch</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background: #f4f6f9; }
        .sidebar {
            height: 100vh;
            background: #1e293b;
            color: white;
            position: fixed;
            width: 220px;
            padding-top: 20px;
        }
        .sidebar a {
            color: #cbd5e1;
            display: block;
            padding: 12px 20px;
            text-decoration: none;
        }
        .sidebar a:hover { background: #334155; color: white; }
        .content { margin-left: 220px; padding: 30px; }
        .card { border-radius: 12px; }
        .admin-reply {
            background: #e8f4fd;
            border-left: 4px solid #0d6efd;
            padding: 10px 15px;
            border-radius: 0 8px 8px 0;
            margin-top: 10px;
        }
    </style>
</head>
<body>

<div class="sidebar">
    <h4 class="text-center mb-4">EduMatch</h4>
    <a href="/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/saved"><i class="bi bi-bookmark me-2"></i> Saved Colleges</a>
    <a href="/feedback"><i class="bi bi-chat-dots me-2"></i> Feedback</a>
    <a href="/profile"><i class="bi bi-person me-2"></i> Profile</a>
    <a href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a>
</div>

<div class="content">
    <h4 class="mb-4"><i class="bi bi-chat-dots-fill text-primary me-2"></i>Feedback</h4>

    <!-- Submit Form -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h6 class="mb-3">Submit your feedback or query</h6>
            <form action="/feedback" method="POST">
                <div class="mb-3">
                    <textarea name="message" class="form-control" rows="4"
                        placeholder="Write your feedback here..." required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send me-2"></i>Submit Feedback
                </button>
            </form>
        </div>
    </div>

    <!-- Previous Feedbacks -->
    <h5 class="mb-3">Your Previous Feedbacks</h5>

    <% if (feedbacks && feedbacks.length > 0) { %>
        <% feedbacks.forEach(function(fb) { %>
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <p class="mb-1"><%= fb.message %></p>
                    <small class="text-muted">
                        <i class="bi bi-clock"></i>
                        <%= new Date(fb.created_at).toLocaleDateString('en-IN') %>
                    </small>

                    <% if (fb.admin_reply) { %>
                        <div class="admin-reply mt-2">
                            <small class="text-primary fw-bold">
                                <i class="bi bi-person-badge me-1"></i>Admin Reply:
                            </small>
                            <p class="mb-0 mt-1"><%= fb.admin_reply %></p>
                        </div>
                    <% } else { %>
                        <div class="mt-2">
                            <span class="badge bg-warning text-dark">
                                <i class="bi bi-hourglass me-1"></i>Awaiting reply
                            </span>
                        </div>
                    <% } %>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>No feedbacks submitted yet.
        </div>
    <% } %>
</div>

<div id="logoutModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:20px; padding:36px; width:380px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
        <div style="width:60px; height:60px; background:#fef2f2; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:28px;">🚪</div>
        <h5 style="font-size:18px; font-weight:700; color:#1e1b4b; margin-bottom:8px;">Leaving so soon?</h5>
        <p style="font-size:13px; color:#6b7280; margin-bottom:24px;">Do you want to logout and go back?</p>
        <div style="display:flex; gap:12px;">
            <button onclick="document.getElementById('logoutModal').style.display='none'"
                style="flex:1; padding:11px; border:1.5px solid #e5e7eb; border-radius:12px; background:white; color:#374151; font-size:14px; font-weight:600; cursor:pointer;">
                Stay
            </button>
            <button onclick="window.location.href='/logout'"
                style="flex:1; padding:11px; border:none; border-radius:12px; background:linear-gradient(135deg,#ef4444,#dc2626); color:white; font-size:14px; font-weight:600; cursor:pointer;">
                Logout
            </button>
        </div>
    </div>
</div>
<script>
    history.pushState(null, null, location.href);
    window.onpopstate = function () {
        history.pushState(null, null, location.href);
        document.getElementById('logoutModal').style.display = 'flex';
    };
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>