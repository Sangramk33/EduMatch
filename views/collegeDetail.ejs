<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= college.name %> | EduMatch</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background: #f4f6f9; }
        .sidebar {
            height: 100vh;
            background: #1e293b;
            color: white;
            position: fixed;
            width: 220px;
            padding-top: 20px;
        }
        .sidebar a {
            color: #cbd5e1;
            display: block;
            padding: 12px 20px;
            text-decoration: none;
        }
        .sidebar a:hover { background: #334155; color: white; }
        .content { margin-left: 220px; padding: 30px; }
        .amenity-card {
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            font-size: 14px;
        }
        .amenity-yes { background: #d1fae5; color: #065f46; }
        .amenity-no  { background: #fee2e2; color: #991b1b; }
    </style>
</head>
<body>

<!-- Sidebar -->
<div class="sidebar">
    <h4 class="text-center mb-4">EduMatch</h4>
    <a href="/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/saved"><i class="bi bi-bookmark me-2"></i> Saved Colleges</a>
    <a href="/profile"><i class="bi bi-person me-2"></i> Profile</a>
    <a href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a>
</div>

<!-- Content -->
<div class="content">

    <a href="/dashboard" class="btn btn-outline-secondary btn-sm mb-4">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>

    <!-- College Header -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h3><%= college.name %></h3>
            <p class="text-muted mb-1">
                <i class="bi bi-geo-alt"></i> <%= college.city %> &nbsp;|&nbsp;
                <i class="bi bi-book"></i> <%= college.course %>
            </p>
            <p class="mb-0">
                <i class="bi bi-bar-chart"></i>
                Last Year Cutoff: <strong><%= college.cutoff_percentage %>%</strong>
            </p>

            <%
                var chances = 'Difficult';
                if (student.cet_percentage >= college.cutoff_percentage + 5) chances = 'Safe';
                else if (student.cet_percentage >= college.cutoff_percentage) chances = 'Moderate';
            %>
            <div class="mt-2">
                <% if (chances === 'Safe') { %>
                    <span class="badge bg-success">✅ Safe — Your chances are good</span>
                <% } %>
                <% if (chances === 'Moderate') { %>
                    <span class="badge bg-warning text-dark">⚠️ Moderate — You can try</span>
                <% } %>
                <% if (chances === 'Difficult') { %>
                    <span class="badge bg-danger">❌ Difficult — Low chances</span>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Amenities -->
    <h5 class="mb-3">Amenities</h5>
    <div class="row g-3 mb-4">

        <div class="col-md-2 col-4">
            <div class="amenity-card <%= college.hostel ? 'amenity-yes' : 'amenity-no' %>">
                <i class="bi bi-house-door fs-4"></i>
                <div class="mt-1">Hostel</div>
                <div><%= college.hostel ? '✅' : '❌' %></div>
            </div>
        </div>

        <div class="col-md-2 col-4">
            <div class="amenity-card <%= college.labs ? 'amenity-yes' : 'amenity-no' %>">
                <i class="bi bi-pc-display fs-4"></i>
                <div class="mt-1">Labs</div>
                <div><%= college.labs ? '✅' : '❌' %></div>
            </div>
        </div>

        <div class="col-md-2 col-4">
            <div class="amenity-card <%= college.library ? 'amenity-yes' : 'amenity-no' %>">
                <i class="bi bi-journal-bookmark fs-4"></i>
                <div class="mt-1">Library</div>
                <div><%= college.library ? '✅' : '❌' %></div>
            </div>
        </div>

        <div class="col-md-2 col-4">
            <div class="amenity-card <%= college.sports ? 'amenity-yes' : 'amenity-no' %>">
                <i class="bi bi-trophy fs-4"></i>
                <div class="mt-1">Sports</div>
                <div><%= college.sports ? '✅' : '❌' %></div>
            </div>
        </div>

        <div class="col-md-2 col-4">
            <div class="amenity-card <%= college.canteen ? 'amenity-yes' : 'amenity-no' %>">
                <i class="bi bi-cup-hot fs-4"></i>
                <div class="mt-1">Canteen</div>
                <div><%= college.canteen ? '✅' : '❌' %></div>
            </div>
        </div>

        <div class="col-md-2 col-4">
            <div class="amenity-card <%= college.wifi ? 'amenity-yes' : 'amenity-no' %>">
                <i class="bi bi-wifi fs-4"></i>
                <div class="mt-1">WiFi</div>
                <div><%= college.wifi ? '✅' : '❌' %></div>
            </div>
        </div>

    </div>

    <!-- Save Button -->
    <a href="/save/<%= college.id %>" class="btn btn-success">
        <i class="bi bi-bookmark-plus"></i> Save this College
    </a>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
        history.pushState(null, null, location.href);
        window.onpopstate = function () {
            history.pushState(null, null, location.href);
            if (confirm("Do you want to logout and go back?")) {
                window.location.href = "/logout";
            }
        };
    </script>

    <div id="logoutModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:20px; padding:36px; width:380px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
        <div style="width:60px; height:60px; background:#fef2f2; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:28px;">🚪</div>
        <h5 style="font-size:18px; font-weight:700; color:#1e1b4b; margin-bottom:8px;">Leaving so soon?</h5>
        <p style="font-size:13px; color:#6b7280; margin-bottom:24px;">Do you want to logout and go back?</p>
        <div style="display:flex; gap:12px;">
            <button onclick="document.getElementById('logoutModal').style.display='none'"
                style="flex:1; padding:11px; border:1.5px solid #e5e7eb; border-radius:12px; background:white; color:#374151; font-size:14px; font-weight:600; cursor:pointer;">
                Stay
            </button>
            <button onclick="window.location.href='/logout'"
                style="flex:1; padding:11px; border:none; border-radius:12px; background:linear-gradient(135deg,#ef4444,#dc2626); color:white; font-size:14px; font-weight:600; cursor:pointer;">
                Logout
            </button>
        </div>
    </div>
</div>
<script>
    history.pushState(null, null, location.href);
    window.onpopstate = function () {
        history.pushState(null, null, location.href);
        document.getElementById('logoutModal').style.display = 'flex';
    };
</script>

</body>
</html>
