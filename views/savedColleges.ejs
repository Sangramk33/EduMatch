<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Saved Colleges | EduMatch</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background: #f4f6f9; }
        .sidebar {
            height: 100vh;
            background: #1e293b;
            color: white;
            position: fixed;
            width: 220px;
            padding-top: 20px;
        }
        .sidebar a {
            color: #cbd5e1;
            display: block;
            padding: 12px 20px;
            text-decoration: none;
        }
        .sidebar a:hover { background: #334155; color: white; }
        .content { margin-left: 220px; padding: 30px; }
        .card { border-radius: 12px; transition: 0.3s; }
        .card:hover { transform: translateY(-5px); }
    </style>
</head>
<body>

<div class="sidebar">
    <h4 class="text-center mb-4">EduMatch</h4>
    <a href="/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
    <a href="/saved"><i class="bi bi-bookmark me-2"></i> Saved Colleges</a>
    <a href="/profile"><i class="bi bi-person me-2"></i> Profile</a>
    <a href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a>
</div>

<div class="content">
    <h4 class="mb-4"><i class="bi bi-bookmark-fill text-success me-2"></i>Saved Colleges</h4>

    <div class="row g-3">
        <% if (colleges && colleges.length > 0) { %>
            <% colleges.forEach(function(college) { %>
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title"><%= college.name %></h5>
                            <p class="text-muted mb-1">
                                <i class="bi bi-geo-alt"></i> <%= college.city %>
                            </p>
                            <p class="mb-2">
                                <i class="bi bi-bar-chart"></i> Cutoff: <strong><%= college.cutoff_percentage %>%</strong>
                            </p>
                            <p class="text-muted" style="font-size:12px">
                                <i class="bi bi-clock"></i> Saved on: <%= new Date(college.saved_at).toLocaleDateString('en-IN') %>
                            </p>
                            <div class="d-flex gap-2">
                                <a href="/college/<%= college.id %>" class="btn btn-sm btn-primary">View Details</a>
                                <a href="/unsave/<%= college.id %>" class="btn btn-sm btn-outline-danger">Remove</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="col-12">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    No colleges saved yet.
                    <a href="/dashboard">Go to Dashboard</a> and save colleges.
                </div>
            </div>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
        history.pushState(null, null, location.href);
        window.onpopstate = function () {
            history.pushState(null, null, location.href);
            if (confirm("Do you want to logout and go back?")) {
                window.location.href = "/logout";
            }
        };
    </script>

    <div id="logoutModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:20px; padding:36px; width:380px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
        <div style="width:60px; height:60px; background:#fef2f2; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:28px;">🚪</div>
        <h5 style="font-size:18px; font-weight:700; color:#1e1b4b; margin-bottom:8px;">Leaving so soon?</h5>
        <p style="font-size:13px; color:#6b7280; margin-bottom:24px;">Do you want to logout and go back?</p>
        <div style="display:flex; gap:12px;">
            <button onclick="document.getElementById('logoutModal').style.display='none'"
                style="flex:1; padding:11px; border:1.5px solid #e5e7eb; border-radius:12px; background:white; color:#374151; font-size:14px; font-weight:600; cursor:pointer;">
                Stay
            </button>
            <button onclick="window.location.href='/logout'"
                style="flex:1; padding:11px; border:none; border-radius:12px; background:linear-gradient(135deg,#ef4444,#dc2626); color:white; font-size:14px; font-weight:600; cursor:pointer;">
                Logout
            </button>
        </div>
    </div>
</div>
<script>
    history.pushState(null, null, location.href);
    window.onpopstate = function () {
        history.pushState(null, null, location.href);
        document.getElementById('logoutModal').style.display = 'flex';
    };
</script>

</body>
</html>
